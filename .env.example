# ============================================================================
# Watsonx AI Configuration
# ============================================================================
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_AI_AUTH_TYPE=iam
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_SERVICE_URL=https://us-south.ml.cloud.ibm.com
MODEL_ID=ibm/granite-4-h-small

# ============================================================================
# Brave Search API (Optional)
# ============================================================================
# Get your API key from: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# ============================================================================
# Build Configuration
# ============================================================================
BUILD_NUMBER=1

# ============================================================================
# IBM Cloud Configuration
# ============================================================================
# IBM Cloud region (e.g., us-south, us-east, eu-gb)
IBM_CLOUD_REGION=us-east

# Code Engine project name
CODE_ENGINE_PROJECT=your-project-name

# Code Engine application name
CODE_ENGINE_APP_NAME=your-app-name

# Container registry namespace
CONTAINER_REGISTRY_NAMESPACE=your-namespace

# IBM Cloud API key (same as WATSONX_API_KEY or separate)
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# ============================================================================
# Proxy Configuration (IBM Corporate Network)
# ============================================================================
# Enable proxy support (set to true if on IBM corporate network)
WX_PROXY_ENABLED=false

# Set proxy URLs (only needed on IBM corporate network)
# HTTP_PROXY=http://proxy.us.ibm.com:8080
# HTTPS_PROXY=http://proxy.us.ibm.com:8080

# Optional: URLs to bypass proxy
# NO_PROXY=localhost,127.0.0.1,.internal.domain

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER commit the actual .env file to version control
# 2. Copy this file to .env and fill in your actual values
# 3. Keep your API keys secure and rotate them regularly
# 4. Use different API keys for development, staging, and production
# 5. Never share your API keys in chat, email, or screenshots
# ============================================================================