# ============================================================================
# SECURITY - Environment Variables and Secrets
# ============================================================================
# CRITICAL: Never commit files containing API keys, tokens, or credentials

# Environment variables
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.*.example

# API keys and credentials
*apikey*
*api-key*
