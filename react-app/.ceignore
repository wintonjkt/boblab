# ============================================================================
# IBM Code Engine Ignore File (.ceignore)
# ============================================================================
# This file specifies which files and directories should be excluded when
# deploying to IBM Code Engine. Similar to .dockerignore but specific to
# Code Engine deployments.
#
# Note: Code Engine uses this file during source-based deployments.
# For container-based deployments, use .dockerignore instead.
# ============================================================================

# ============================================================================
# SECURITY - Never Deploy Secrets
# ============================================================================
.env
.env.*
.env.local
.env.production.local
.env.development.local
.env.test.local
!.env.example

# API keys and credentials
*apikey*
*api-key*
*api_key*
*token*
*secret*
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
credentials/
secrets/
ibmcloud-apikey.json
watsonx-credentials.json
watsonx-apikey.json

# ============================================================================
# Development Dependencies
# ============================================================================
node_modules/
.bun/
bun.lockb
jspm_packages/
bower_components/

# ============================================================================
# Build Outputs (if using source deployment)
# ============================================================================
# Note: For container deployments, these are handled by Dockerfile
dist/
dist-ssr/
build/
*.local

# ============================================================================
# Development Files
# ============================================================================
# Source files (not needed in production container)
src/
tests/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/

# TypeScript source (compiled to dist/)
*.ts
*.tsx
!*.d.ts

# Development configs
tsconfig.json
tsconfig.*.json
vite.config.ts
playwright.config.ts

# ============================================================================
# Testing
# ============================================================================
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
.cache/

# ============================================================================
# Documentation (not needed in runtime)
# ============================================================================
README.md
CHANGELOG.md
LICENSE
*.md
!SECURITY.md
docs/

# ============================================================================
# Git
# ============================================================================
.git/
.gitignore
.gitattributes
.github/

# ============================================================================
# CI/CD
# ============================================================================
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
.circleci/
.jenkins/

# ============================================================================
# IDEs and Editors
# ============================================================================
.vscode/
.idea/
*.iml
*.swp
*.swo
*.swn
*~
.*.sw?
*.sublime-workspace
*.sublime-project

# ============================================================================
# Operating Systems
# ============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================================
# Temporary Files
# ============================================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.cache

# ============================================================================
# Deployment Scripts (not needed in container)
# ============================================================================
deploy.sh
deploy-with-apikey.sh
verify-deployment.sh
debug-env.sh
*.sh

# ============================================================================
# Container Files (handled separately)
# ============================================================================
Dockerfile
.dockerignore
docker-compose.yml
.docker/

# ============================================================================
# Package Manager Files (not needed in runtime)
# ============================================================================
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lock

# ============================================================================
# Miscellaneous
# ============================================================================
.sass-cache/
*.css.map
*.js.map
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ============================================================================
# IBM Cloud Specific
# ============================================================================
.bluemix/
.ibmcloud/
deployment-logs/
code-engine-logs/
registry-credentials.json

# ============================================================================
# Keep These Files (Important for Deployment)
# ============================================================================
# The following files SHOULD be included in deployment:
# - nginx.conf (web server configuration)
# - dist/ (built application - if using container deployment)
# - package.json (for dependency information)
# - .env.example (template for environment variables)
# - SECURITY.md (security documentation)