# Environment Variables for Bob Lab React Application
# Copy this file to .env.local and update with your values

# ============================================================================
# Application Configuration
# ============================================================================

# Node environment (development, production, test)
NODE_ENV=production

# Application version (displayed in UI)
VITE_APP_VERSION=1.0.0

# Application name
VITE_APP_NAME="Bob Lab"

# ============================================================================
# API Configuration
# ============================================================================

# Base URL for API calls (if using external APIs)
# Example: https://api.example.com/v1
VITE_API_BASE_URL=

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# API key for external services (if needed)
# IMPORTANT: Never commit actual API keys to version control
VITE_API_KEY=

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable features
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_SEARCH=true
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_I18N=true
VITE_FEATURE_PROGRESS_TRACKING=true

# ============================================================================
# Analytics Configuration
# ============================================================================

# Google Analytics ID (if using)
VITE_GA_TRACKING_ID=

# IBM Analytics ID (if using)
VITE_IBM_ANALYTICS_ID=

# ============================================================================
# Internationalization (i18n)
# ============================================================================

# Default language
VITE_DEFAULT_LANGUAGE=en

# Available languages (comma-separated)
VITE_AVAILABLE_LANGUAGES=en,ko,zh-CN,zh-TW,hi,ms,vi,th,id

# ============================================================================
# Theme Configuration
# ============================================================================

# Default theme (light, dark, system)
VITE_DEFAULT_THEME=system

# ============================================================================
# Code Engine / Deployment Configuration
# ============================================================================

# Base path for the application (useful for subdirectory deployments)
# Example: /bob-lab for https://example.com/bob-lab
VITE_BASE_PATH=/

# Public URL (used for absolute URLs)
# Example: https://bob-lab.example.com
VITE_PUBLIC_URL=

# ============================================================================
# IBM Cloud Deployment Configuration (for deploy-with-apikey.sh)
# ============================================================================
# IMPORTANT: These variables should be set in the parent directory's .env file
# The deployment script will read from ../env

# IBM Cloud API Key (required for authentication)
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=your_api_key_here

# IBM Cloud Region (where to deploy)
# Options: us-south, us-east, eu-gb, eu-de, jp-tok, au-syd, etc.
IBM_CLOUD_REGION=us-south

# IBM Cloud Resource Group
# Default is "default", or specify your custom resource group
IBM_CLOUD_RESOURCE_GROUP=default

# Code Engine Project Name
# The project must exist or will be created
CODE_ENGINE_PROJECT=bob-lab-project

# Code Engine Application Name
# This is the name of your deployed application
CODE_ENGINE_APP_NAME=bob-lab-app

# Container Registry Namespace
# Create one at: https://cloud.ibm.com/registry/namespaces
# Must be unique across IBM Cloud
CONTAINER_REGISTRY_NAMESPACE=your_namespace_here

# Container Image Name (optional, defaults to bob-lab)
CONTAINER_IMAGE_NAME=bob-lab

# Container Image Tag (optional, defaults to latest)
CONTAINER_IMAGE_TAG=latest

# ============================================================================
# External Services
# ============================================================================

# IBM watsonx API endpoint (if integrating with watsonx)
VITE_WATSONX_API_URL=

# IBM Cloud region
VITE_IBM_CLOUD_REGION=us-south

# ============================================================================
# Development Configuration
# ============================================================================

# Enable debug mode (shows additional logging)
VITE_DEBUG=false

# Enable source maps in production
VITE_SOURCEMAP=false

# ============================================================================
# Security Configuration
# ============================================================================

# Content Security Policy (CSP) nonce (if using)
VITE_CSP_NONCE=

# ============================================================================
# Performance Configuration
# ============================================================================

# Enable performance monitoring
VITE_PERFORMANCE_MONITORING=false

# Lazy load threshold (in milliseconds)
VITE_LAZY_LOAD_THRESHOLD=300

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (error, warn, info, debug)
VITE_LOG_LEVEL=info

# Enable remote logging
VITE_REMOTE_LOGGING=false

# Remote logging endpoint
VITE_REMOTE_LOGGING_URL=

# ============================================================================
# Notes
# ============================================================================

# 1. Variables prefixed with VITE_ are exposed to the client-side code
# 2. Never commit sensitive data (API keys, secrets) to version control
# 3. Use different .env files for different environments:
#    - .env.local (local development, gitignored)
#    - .env.development (development environment)
#    - .env.production (production environment)
# 4. In Code Engine, set environment variables using configmaps or secrets
# 5. Boolean values should be lowercase strings: "true" or "false"
# 6. Empty values will use application defaults